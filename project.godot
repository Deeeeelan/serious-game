; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Serious Game"
run/main_scene="uid://dbjxrtbe8nvgs"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="res://assets/placeholders/icon.svg"

[audio]

buses/default_bus_layout="uid://d20ly2q15ecw3"

[autoload]

GameRecipes="*uid://chqhld841hk4g"
GameStats="*uid://vwgmg8r4a6qb"

[display]

window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_super-wakatime/plugin.cfg")

[file_customization]

folder_colors={
"res://assets/": "orange",
"res://scenes/": "purple",
"res://scripts/": "red"
}

